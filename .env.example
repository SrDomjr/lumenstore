# ============================================================
# LumenStore - Variables de Entorno (Plantilla)
# ============================================================
# Copia este archivo a .env y completa tus valores reales:
#   cp .env.example .env

# === BASE DE DATOS ===
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lumenstore
DB_USERNAME=
DB_PASSWORD=

# === JWT ===
# Genera una clave de al menos 32 caracteres:
#   openssl rand -base64 48
JWT_SECRET=
JWT_EXPIRATION=36000000

# === CLOUDINARY (Backend) ===
# Obtén tus credenciales en https://console.cloudinary.com/
CLOUDINARY_ENABLED=true
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# === SERVIDOR ===
SERVER_PORT=8080

# === CORS ===
# Orígenes permitidos separados por coma
CORS_ALLOWED_ORIGINS=http://localhost:4200

# === FRONTEND (Angular) ===
# cloud_name de Cloudinary (valor público, se usa en URLs de imágenes)
NG_APP_CLOUDINARY_CLOUD_NAME=
